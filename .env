APP_NAME=Enterprise Auth Service

# DATABASE_URL=postgresql://postgres:postgres123@localhost/authdb
# DATABASE_URL=postgresql://postgres:postgres123@host.docker.internal:5432/authdb, for normal docker set up, I mean with only dockerfile but not with docker-compose
DATABASE_URL=postgresql://postgres:postgres123@postgres:5432/authdb

SECRET_KEY=THIS_IS_MY_SUPER_SECRET_KEY_123456789

ALGORITHM=HS256

ACCESS_TOKEN_EXPIRE_MINUTES=30

OTP_EXPIRE_MINUTES=5

OTP_MAX_ATTEMPTS=3